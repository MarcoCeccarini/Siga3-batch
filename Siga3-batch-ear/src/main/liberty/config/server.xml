<server description="defaultServer">
	<featureManager>
	<feature>jakartaee-10.0</feature>
    <feature>mpOpenAPI-4.0</feature>
    <feature>localConnector-1.0</feature>
	</featureManager>
																																					
	
	<basicRegistry id="defaultBasicRegistry"
		realm="BasicRealm">
		<user name="username" password="password" />
	</basicRegistry>

	<library id="OracleLib">
		<fileset dir="${server.config.dir}" includes="ojdbc8.jar" />
	</library>

	<variable name="CONTEXT_ROOT" value="${env.CONTEXT_ROOT:/backend-siga-business-batch}" />
	<variable name="APP_NAME" value="${env.APP_NAME:backend-siga-business-batch}" />

	<dataSource id="DefaultDataSource"
		jdbcDriverRef="oracle.driver" jndiName="jdbc/siga3"
		transactional="true" type="javax.sql.DataSource">
		<properties.oracle
			URL="${env.SIGA3_ORACLE_URL}"
			user="${env.SIGA3_ORACLE_USER}" password="${env.SIGA3_ORACLE_PASSWORD}" />
		<connectionManager maxPoolSize="30" minPoolSize="1" connectionTimeout="60s" />
	</dataSource>
	<jdbcDriver id="oracle.driver" libraryRef="OracleLib">
		<javax.sql.DataSource>oracle.jdbc.pool.OracleDataSource</javax.sql.DataSource>
	</jdbcDriver>

	<persistentExecutor id="defaultEJBPersistentTimerExecutor" dataSourceRef="DefaultDataSource" />
	
	<transaction defaultTimeout="600" />
	
	<managedExecutorService maxPoolSize="20"/>


	<keyStore id="defaultKeyStore" password="password" />
	<httpEndpoint id="defaultHttpEndpoint" host="*"
		httpPort="9080" httpsPort="9443" />

	<applicationMonitor startTimeout="120s" />
	<config updateTrigger="mbean" />

	<logging consoleLogLevel="INFO" traceSpecification="
  com.ibm.ws.jaxrs.*=all:
  com.ibm.ws.openapi.*=all:
  com.ibm.ws.microprofile.openapi.*=all:
  com.ibm.ws.security.*=all:
  EclipseLink.sql=FINE:
  EclipseLink.query=FINE:
  EclipseLink.parameters=FINE:
  EclipseLink.transaction=FINE:
  EclipseLink.logging.exceptions=FINEST:
  com.ibm.ws.transaction.*=all
"/>

	<enterpriseApplication id="Siga3-batch"
						   location="Siga3-batch-ear-1.0.0-SNAPSHOT.ear"
						   name="Siga3-batch-ear"/>
